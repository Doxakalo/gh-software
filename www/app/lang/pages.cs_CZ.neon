customapps:
    metadata:
        title: "Aplikace na míru"
        description: "Vyvineme softwarové aplikace ušité na míru Vašim specifickým potřebám. Používáme platformu FileMaker, abychom dodali řešení rychle a spolehlivě."
        og:
            title: "24U: Aplikace na míru"
            description: "Vyvineme softwarové aplikace ušité na míru Vašim specifickým potřebám. Používáme platformu FileMaker, abychom dodali řešení rychle a spolehlivě. Naši lidé zajistí, že váš software bude pracovat nejlépe. Nechce si vaši aplikaci vytvořit od nás."

    default:
        header-title: "Vyvineme softwarové aplikace<br />ušité na míru Vašim<br /><strong>specifickým potřebám</strong>"

        service-tabs:
            effeciency:
                label: "Efektivita"
                text: "Používáme<br />platformu FileMaker,<br />abychom dodali<br />výsledek rychle"
            technology:
                label: "Technologie"
                text: "Databáze, web,<br />mobilní zařízení,<br />Mac, Windows,<br />Linux, Raspberry Pi"
            hw:
                label: "Hardware"
                text: "Skenery, tiskárny,<br />senzory, váhy,<br />RFID, NFC<br />a další"
            redundancy:
                label: "Zastupitelnost"
                text: "Na každém projektu<br />vždy pracují<br />nejméně dva<br />vývojáři"
            reliability:
                label: "Spolehlivost"
                text: "Full-time testeři<br />zajišťují,<br />aby náš software<br />pracoval správně"

        articles:
            read-more: "Více informací"

hw-integrations:
    metadata:
        title: "Integrace hardware"
        description: "Umíme váš software propojit s jakýmkoli hardwarem. Integrujeme mobilní tiskárny, čtečky čárových kódů, RFID a NDC, digitální váhy i různá speciální zařízení."
        og:
            title: "24U: Integrace hardware"
            description: "Umíme váš software propojit s jakýmkoli hardwarem, a tak zefektivnit vaše podnikání. Integrujeme mobilní tiskárny, čtečky čárových kódů, RFID a NDC, platební terminály, digitální váhy i různá speciální zařízení."

    default:
        header-title: "Získávejte data<br/>z fyzického světa,<br />ovládejte fyzický svět daty"

        card-boxes:
            mobile_printers:
                label: "Mobilní tiskárny"
                text: "Tiskněte účtenky, ať jste kdekoli, přímo z iPhonu nebo iPadu"
            security_dongles:
                label: "Bezpečnostní klíče"
                text: "Ochraňte svá data nebo duševní vlastnictví silným šifrováním v hardwarovém klíči"
            rfid:
                label: "RFID a NFC"
                text: "Sledujte pohyb zboží, majetku a lidí pomocí čtení a zápisu RFID a NFC čipů"
            barcode:
                label: "Čtečky čárových kódů"
                text: "Sledujte pohyb zboží, majetku a lidí pomocí čárových kódů"
            pay_terminals:
                label: "Platební terminály"
                text: "Přijímejte platby kartou přímo do vaší aplikace na iPadu nebo iPhonu"
            scales:
                label: "Digitální váhy"
                text: "Načítejte hmotnost zboží a surovin z malé či velké digitální váhy přímo do vaší aplikace"
            motors:
                label: "Servo a krokové motory"
                text: "Hýbejte věcmi kolem vás pomocí motorů ovládaných přímo z vaší aplikace na míru"
            smart_cards:
                label: "Chytré karty"
                text: "Integrujte do své aplikace chytré karty pro identifikaci či ukládání dat"
            medical_devices:
                label: "Zdravotnické přístroje"
                text: "Poskytněte lepší péči efektivním zpracováním dat z vyšetření pacientů"
            led_strips:
                label: "LED pásky"
                text: "Ovládněte pásky s RGB LED světly pro indikaci pozice nebo statusu či upoutání pozornosti uživatele"
            lcd:
                label: "LCD displeje"
                text: "Zobrazujte data na LCD displejích a implementujte speciální uživatelské rozhraní, jako je např. pokladna"
            telephony:
                label: "Telefonie"
                text: "Když vaše aplikace ví, kdo volá, pomůže vám ušetřit čas a lépe se postarat o zákazníky"
            arduino:
                label: "Arduino"
                text: "Rozšiřte vaše aplikace s populární open-source hardwarovou platformou"
            raspberry:
                label: "Raspberry Pi"
                text: "Nasaďte samostatné chytré řešení integrované s aplikací na míru"
            sensors:
                label: "Senzory"
                text: "Sbírejte data o prostředí, jako je teplota, přímo do vaší databáze"
            phidgets:
                label: "Phidgets"
                text: "Nechte své aplikace vnímat a ovládat fyzický svět s chytrými zařízeními Phidgets"


fm-consulting:
    metadata:
        title: "Konzultace FileMaker"
        description: "Naučíme platformu FileMaker pracovat pro vás tak, jak chcete. Máme 30 let zkušeností a každý člen našeho FileMaker týmu je certifikovaný vývojářem."
        og:
            title: "24U: Konzultace FileMaker"
            description: "Naučíme platformu FileMaker pracovat pro vás tak, jak chcete. Máme 30 let zkušeností a každý člen našeho FileMaker týmu je certifikovaný vývojářem, takže dokážeme poskytnout vysoce odborné poradenství všem zákazníkům a vývojářům."

    default:
        header-title: "Naučte platformu FileMaker<br />pracovat pro vás tak, jak chcete,<br />s naší odbornou pomocí"


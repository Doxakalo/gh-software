homepage:
    metadata:
        title: ""
        description: "Software. Hardware. Mobil. Web. FileMaker. Firma. Lidi. Propojíme je, aby spolu pracovali pro Vás."
        og:
            title: "24U: Software pro lidi, ne pro počítače"
            description: "Vynikáme ve vývoji nových a péči o stávající aplikace na míru, optimalizaci jejich rychlosti, odhalování a řešení hrozících rizik, zlepšování spolehlivosti, stability a škálovatelnosti, integraci s dalšími systémy, včetně rozličných hardwarových zařízení, a rozšiřování jejich možností nad očekávání."

    service-tabs:
        custom_apps:
            label: "Aplikace<br />na míru"
            text: "To, že pracujete<br />jinak než ostatní<br />je vaše<br />konkurenční výhoda"
        fm_consulting:
            label: "Konzultace<br />FileMaker"
            text: "Pomůžeme vašim<br />vývojářům<br />postarat se o vaše<br />FileMaker aplikace"
        hw_integrations:
            label: "Integrace<br />hardware"
            text: "Zajistíme, aby<br />vaše systémy<br />úzce spolupracovali<br />s fyzickým světem"
        sla:
            label: "Servisní<br />smlouvy"
            text: "Složte činnosti<br />co byste měli dělat<br />pro své bezpečí<br />na naše bedra"


fm-licensing:
    metadata:
        title: "Claris FileMaker"
        description: "Jako Claris Platinum Partner a autorizovaný prodejce vám můžeme pomoci zajistit novou licenci nebo prodloužení té stávající, s přidanou hodnotou, kdekoli na světě."
        og:
            title: "24U: Claris FileMaker"
            description: "Jako Claris Platinum Partner a autorizovaný prodejce vám můžeme pomoci zajistit novou licenci nebo prodloužení té stávající za stejnou cenu jako přímo od výrobce, navíc s přidanou hodnotou našich služeb, a to bez ohledu na to, odkud jste nebo jako měnou platíte."

    default:
        header-title: "Claris<sup>&reg;</sup> FileMaker<sup>&reg;</sup>"

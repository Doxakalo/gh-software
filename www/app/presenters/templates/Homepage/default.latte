        {* -- SimpleDialog -- *}
        <div class="tile gr-6 gr-12@mobile no-gutter padding-right padding-bottom" data-hightlight="true" data-hightlight-is-second="true"  data-highlight-full-width="false">
            <a n:href="Tools:simpleDialog" class="overlay" style="background-image: url('{$basePath}/img/pages/homepage/card_boxes/simpledialog/simple_dialog.jpg')"> {* TODO - Insert LINK *}
                <div class="rollover" style="background-image: url('{$basePath}/img/pages/homepage/card_boxes/simpledialog/simple_dialog_rollover.jpg')"></div>

        {* -- Phone Companion -- *}
        <div class="tile gr-6 gr-12@mobile no-gutter padding-right padding-bottom" data-hightlight="true" data-hightlight-is-second="false"  data-highlight-full-width="false">
            <a n:href="Tools:phoneCompanion" class="overlay" style="background-image: url('{$basePath}/img/pages/homepage/card_boxes/phone_companion/cover.jpg')"> {* TODO - Insert LINK *}
                <div class="rollover" style="background-image: url('{$basePath}/img/pages/homepage/card_boxes/phone_companion/cover_rollover.jpg')"></div>
                <div class="content">
                    {include phone_companion_preview}
                </div>
            </a>
        </div>

        {* -- Xgode -- *}
        <div class="tile gr-6 gr-12@mobile no-gutter padding-left padding-bottom" data-hightlight="true" data-hightlight-is-second="true"  data-highlight-full-width="false">
            <a n:href="Tools:xgode" class="overlay" style="background-image: url('{$basePath}/img/pages/homepage/card_boxes/xgode/cover.jpg')"> {* TODO - Insert LINK *}
                <div class="rollover" style="background-image: url('{$basePath}/img/pages/homepage/card_boxes/xgode/cover_rollover.jpg')"></div>
                <div class="content">
                    {include xgode_preview}
                </div>
            </a>
        </div>

        {* -- Scavent -- *}
        <div class="tile gr-12 no-gutter padding-bottom" data-hightlight="true" data-hightlight-is-second="false" data-highlight-full-width="true">
            <a n:href="ProductPages:scavent" class="overlay" style="background-image: url('{$basePath}/img/pages/homepage/card_boxes/scavent/cover.jpg')"> {* TODO - Insert LINK *}
                <div class="rollover" style="background-image: url('{$basePath}/img/pages/homepage/card_boxes/scavent/cover_rollover.jpg')"></div>
                <div class="content">
                    {include scavent_preview}
                </div>
            </a>
        </div>
    </div>
</section>

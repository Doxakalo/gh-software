                            <a href="{$basePath}/plugins-data/phonecompanion/doc/v303/phc-schema-offsite.pdf" target="_blank" class="button download-tech-doc">Offsite implementation</a>
                            <a href="{$basePath}/plugins-data/phonecompanion/doc/v303/phc-scheme-customization-trunk.pdf" target="_blank" class="button download-tech-doc">Multiple trunk lines</a>
                            <a href="{$basePath}/plugins-data/phonecompanion/doc/v303/phc-scheme-voip-architecture.png" target="_blank" class="button download-tech-doc">VOIP implementation</a>
                        </div>
                    </div>
                </div>
            </li>
            <li>
                <div class="version-submenu-headline">

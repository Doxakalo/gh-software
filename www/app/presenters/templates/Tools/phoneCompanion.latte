{block title}Phone Companion{/block}
{block description}
    Phone Companion ties FileMaker<sup>&reg;</sup> Pro to your PBX to give your database solution a full control over your phone
{/block}

{block og}
    {ifset $appConfig["og"]}
        {include meta-og,
            type => $appConfig["og"]["type"],
            title => "Phone Companion",
            description => "Phone Companion ties FileMaker&reg; Pro to your PBX to give your database solution a full control over your phone.",
            imagePath => "img/pages/tools/phone-companion/og_image.png",
            siteName => $appConfig["og"]["site_name"]}
    {/ifset}
{/block}

{block content}

<section class="cover-sticky" id="fixedCover">
    <div class="container">
        <div class="row row-align-middle">
            <div class="gr-12">
                <div class="title"></div>
            </div>
        </div>
    </div>
</section>


<section class="cover default plugins" style="background-image: url('{$basePath}/img/pages/tools/cover-2_objectmask.jpg')">
    <div class="inner-background cover-parallax" style="background-image: url('{$basePath}/img/pages/tools/cover-2_objectmask.jpg')"></div>
    <div class="container">
        <div class="row row-align-middle cover-parallax-inner">
            <div class="gr-3 no-gutter gr-10@mobile gr-12@mobileSmall gr-centered@mobile headline text-left text-left@mobile-center">
                <img src="{$basePath}/img/icons/phone-companion_icon.svg" alt="Phone Companion">
            </div>
            <div class="gr-6 gr-12@mobile text-left@mobile-center">
                <h1 class="page-title plugins-page">
                    <strong>{$toolName}</strong>
                    <div class="description">
                        CALL NOW <br/> from FileMaker<sup>&reg;</sup> Pro
                    </div>
                </h1>
                <div class="page-button">
                    <div class="button buy-button">Buy</div>
                    <div class="button download-button">Download</div>
                </div>
            </div>
        </div>
    </div>
</section>

{import 'translate/phoneCompanion_en.latte'}
{var $overview = [
    name => 'overview',
    testimonials => [
        [ img => $basePath.'/img/testimonials/a_hinshaw.jpg', video => [id => 'kygEPvI9dBA'], name => 'Andrew Hinshaw', ],
        [ img => $basePath.'/img/testimonials/ch_oster.jpg', video => [id => 'bZ7choIgNik'], name => 'Chad Oster', ],
    ]
] }
{import '../Components/articles.latte'}
{include article-overview, $overview}

{var $articles = [
    [name => 'dial', img => $basePath.'/img/pages/tools/phone-companion/call.png' ],
    [name => 'notify', img => $basePath.'/img/pages/tools/phone-companion/phc-incoming.png' ],
    [name => 'record', img => $basePath.'/img/pages/tools/phone-companion/record_calls.png', img_url =>[url => $basePath.'/img/pages/tools/phone-companion/record_calls.png', target => '_blank'] ],
    [name => 'complex', img => $basePath.'/img/pages/tools/phone-companion/support_process.png' ],
    [name => 'callcenters', img => $basePath.'/img/pages/tools/phone-companion/callcenter_illustration.png', img_height => '200' ],
    [name => 'pbx', img => $basePath.'/img/pages/tools/phone-companion/unusualsetups.png', img_height => '200', img_url =>[url => $basePath.'/img/pages/tools/phone-companion/unusualsetups.png', target => '_blank'] ],
    [name => 'phonecompanion3', img => $basePath.'/img/pages/tools/phone-companion/og_image.png', img_height => '200' ],
    [name => 'voip', img => $basePath.'/img/pages/tools/phone-companion/snoom_phone.png' ],
    [name => 'support', img => $basePath.'/img/pages/tools/phone-companion/mitel_snoom_macmini.png', img_height => '250' ],
    [name => 'ext_scripts', img => $basePath.'/img/pages/tools/phone-companion/script_step.png' ],
    [name => 'how_it_works', img => $basePath.'/img/pages/tools/phone-companion/how_it_works_w400.png', img_height => '250' ],
    [name => 'compatibility', img => $basePath.'/img/pages/tools/phone-companion/ustredna_w350.png', img_height => '200' ],
] }
{import '../Components/articles.latte'}
{include article-list, $articles}


{snippet storeForm}
    {include '../Components/store-section.latte', toolName => $toolName}
{/snippet}

{capture $downloadVersionsHtml}
    <div class="version" data-active="false">
        <div class="basic-info">
            <div class="version-name">
                v3.0.3
            </div>
            <div class="release-date">
                <strong>Release date: </strong>
                {$releaseDate = "2021/09/24"|genericFormatDate}
            </div>
        </div>
        <ul class="version-submenu">
            <li>
                <div class="version-submenu-headline">
                    Technical documentation
                </div>

                <div class="detail tech-doc">
                    <div class="row">
                        <div class="gr-12">
                            If you are a developer going to implement this product, here you can examine its technical documentation to get a better understanding on how it works and how
                            you can use it.
                        </div>
                    </div>
                    <div class="row text-center">
                        <div class="gr-12">

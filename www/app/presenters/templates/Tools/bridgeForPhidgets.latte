{block title}Bridge for Phidgets - Sense and control the physical world with smart Phidgets devices{/block}
{block description}
    Thanks to this plug-in FileMaker<sup>&reg;</sup> solutions can now interact with users via professionally looking dialogs. Easily.
{/block}

{block og}
    {ifset $appConfig["og"]}
        {include meta-og,
        type => $appConfig["og"]["type"],
        title => "Bridge for Phidgets",
        description => "This plug-in lets you connect different kind of phidgets to your computer's USB port and interact with them directly from FileMaker&reg; Pro.",
        imagePath => "img/pages/tools/bridge-for-phidgets/og_image.png",
        siteName => $appConfig["og"]["site_name"]}
    {/ifset}
{/block}

{block content}
{* VIDEO - DETECT RESOLUTION *}
{if $detect['platformDevice'] === "tablet"}
    {var $videoResolution = "640"}
{elseif $detect['platformDevice'] === "phone"}
    {var $videoResolution = "640"}
{else}
    {var $videoResolution = "640"}
{/if}

{import '../Components/tools_videoplayer.latte'}

<section class="cover-sticky" id="fixedCover">
    <div class="container">
        <div class="row row-align-middle">
            <div class="gr-12">
                <div class="title"></div>
            </div>
        </div>
    </div>
</section>


<section class="cover default plugins" style="background-image: url('{$basePath}/img/pages/tools/cover-2_objectmask.jpg')">
    <div class="inner-background cover-parallax" style="background-image: url('{$basePath}/img/pages/tools/cover-2_objectmask.jpg')"></div>
    <div class="container">
        <div class="row row-align-middle cover-parallax-inner">
            <div class="gr-3 no-gutter gr-10@mobile gr-12@mobileSmall gr-centered@mobile headline text-left text-left@mobile-center">
                <img src="{$basePath}/img/icons/phidgets_purple_icon.svg" alt="Phidgets">
            </div>
            <div class="gr-6 gr-12@mobile text-left@mobile-center">
                <h1 class="page-title plugins-page">
                    <strong>{$toolName}</strong>
                    <div class="description">
                        Sense and control the physical<br/> world with smart Phidgets devices
                    </div>
                </h1>
                <div class="page-button">
                    <div class="button buy-button">Buy</div>
                    <div class="button download-button">Download</div>
                </div>
            </div>
        </div>
    </div>
</section>

{import 'translate/bridgeForPhidgets_en.latte'}
{var $overview = [
name => 'overview',
testimonials => [
[ img => $basePath . '/img/testimonials/joe_byrne.jpg', video => [id => 'H5Inu35fkuc'], name => 'Joe Byrne', ],
[ img => $basePath . '/img/testimonials/owen_caldwell.jpg', video => [id => 'yECNeZpVnsY' ], name => 'Owen Caldwell', ],
[ img => $basePath . '/img/testimonials/jacques_kirouac.jpg', video => [id => '53A9RU00jJ8'], name => 'Jacques Kirouac', ],
[ img => $basePath . '/img/pages/tools/bridge-for-phidgets/preview_video_image_u56SliBmxmk.jpg', video => [id => 'u56SliBmxmk'], name => 'HOnza Koudelka', ],

]
]}
{import '../Components/articles.latte'}
{include article-overview, $overview}
{*

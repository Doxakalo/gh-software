{var $articles = [
[name => 'read_write', video-mp4 => [folderName => 'phidgets', fileNamePrefix=> 'rfid', videoResolution => $videoResolution]],
[name => 'capture_data', video-mp4 => [folderName => 'phidgets', fileNamePrefix=> 'capture_data', videoResolution => $videoResolution]],
[name => 'servo_motor',
video-compilation => [
[videoType => "video-mp4",  folderName => 'phidgets', fileNamePrefix=> 'servo_motor', videoResolution => $videoResolution],
[videoType => "video-mp4",  folderName => 'phidgets', fileNamePrefix=> 'stepper_motor', videoResolution => $videoResolution],
]],
[name => 'tlakovy_sensor', video-mp4 => [folderName => 'phidgets', fileNamePrefix=> 'tlakovy_sensor', videoResolution => $videoResolution]],
[name => 'led', video-mp4 => [folderName => 'phidgets', fileNamePrefix=> 'ledka', videoResolution => $videoResolution]],
[name => 'lcd', video-mp4 => [folderName => 'phidgets', fileNamePrefix=> 'lcd', videoResolution => $videoResolution]],
[name => 'network', img => $basePath . '/img/pages/tools/bridge-for-phidgets/network.jpg' ],
[name => 'vint', img => $basePath . '/img/pages/tools/bridge-for-phidgets/vint.png', img_height => '300' ],
[name => 'iphone', img => $basePath . '/img/pages/tools/bridge-for-phidgets/iphone.png', img_height => '250', img_url =>[url => $basePath . '/img/pages/tools/bridge-for-phidgets/iphone.png', target => '_blank'] ],
[name => 'filemaker-support-server',         video-compilation => [
[videoType => "video-yt", id => 'eNKEtMXI134', title=> 'Monitor FileMaker Server Temperature with 24U Bridge for Phidgets 4', button-dark=>"white", img => $basePath.'/img/pages/tools/bridge-for-phidgets/preview_video_image_eNKEtMXI134.jpg' ],
] ],

]}
{import '../Components/articles.latte'}
{include article-list, $articles}

{snippet storeForm}
    {include '../Components/store-section.latte', toolName => $toolName}
{/snippet}


<section class="tools-items">
    <div class="container">
        <div class="row row-full">
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider first" data-href="{link Tools:bridgeForArduino}">
                    <img src="{$basePath}/img/icons/bridge_for_arduino_icon.svg" class="limited-height-130 mb-1" alt="Bridge for Arduino">
                    <h2>Bridge for Arduino</h2>
                    <p>
                        Extend your apps with the popular open-source hardware platform
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:bridgeForArduino#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider last" data-href="{link Tools:bridgeForPhidgets}">
                    <img src="{$basePath}/img/icons/phidgets_purple_icon.svg" class="limited-height-130 mb-1" alt="Bridge for Phidgets">
                    <h2>Bridge for Phidgets</h2>
                    <p>
                        Sense and control the physical world with smart Phidgets devices
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:bridgeForPhidgets#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="tools-items  light-blue">
    <div class="container">
        <div class="row row-full">
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider first" data-href="{link Tools:gonector}">
                    <img src="{$basePath}/img/icons/gonector_icon.svg" class="limited-height-130 mb-1@mobile" alt="Gonector">
                    <h2>Gonector</h2>
                    <p class="limited">
                        Connect anything to your mobile FileMaker app.
                        RFID/NFC scanner, Barcode scanner, Receipt or label printer, Weighing scale, Payment terminal…
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:gonector#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider last" data-href="/phonecompanion">
                    <img src="{$basePath}/img/icons/phone-companion_icon.svg" class="limited-height-130 mb-1" alt="SimpleFile">
                    <h2>Phone Companion</h2>
                    <p>
                        Your system can know who’s calling even before you know it.
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:phoneCompanion#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="tools-items">
    <div class="container">
        <div class="row row-full">
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider first" data-href="/simpledialog">
                    <img src="{$basePath}/img/icons/simple-dialog_icon.svg" class="limited-height-130 mb-1" alt="SimpleDialog">
                    <h2>SimpleDialog</h2>
                    <p>
                        Interact with users via professionally looking dialogs. Easily
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:simpleDialog#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider last" data-href="/simplefile">
                    <img src="{$basePath}/img/icons/simple-file_icon.svg" class="limited-height-130 mb-1" alt="SimpleFile">
                    <h2>SimpleFile</h2>
                    <p>
                        Create, delete, copy, move, rename, read and edit files and folders. Easily
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:simpleFile#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="tools-items light-blue">
    <div class="container">
        <div class="row row-full">
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider first" data-href="/simpletalk">
                    <img src="{$basePath}/img/icons/simple-talk_icon.svg" class="limited-height-130 mb-1" alt="PhoneCompanion">
                    <h2>SimpleTalk</h2>
                    <p>
                        Make your app talk to other apps or devices over network. Easily
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:simpleTalk#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider last" data-href="/simplehasp">
                    <img src="{$basePath}/img/pages/tools/simple-hasp/og_image.png" class="limited-height-130 mb-1" alt="SimpleTalk">
                    <h2>SimpleHASP</h2>
                    <p>
                        Protect data and intellectual property with hardware dongles.
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:simpleHASP#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="tools-items">
    <div class="container">
        <div class="row row-full">
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider first" data-href="/simplesound">
                    <img src="{$basePath}/img/pages/tools/simple-sound/og_image.png" class="limited-height-130 mb-1" alt="PhoneCompanion">
                    <h2>SimpleSound</h2>
                    <p>
                        Make your custom app heard. Easily
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:simpleSound#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
            <div class="no-gutter gr-6 gr-12@mobile">
                <div class="item divider last" data-href="/toolbox">
                    <img src="{$basePath}/img/pages/tools/toolbox/og_image.png" class="limited-height-130 mb-1" alt="SimpleTalk">
                    <h2>Toolbox</h2>
                    <p>
                        Use missing FileMaker features. Today
                    </p>
                    <p class="mb-0">
                        <a n:href="Tools:toolbox#buy" class="button mb-0">Buy</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="spacing light-blue">
    <div class="container">
        <div class="row">
            <div class="gr-12 text-center">
                <h2 class="large">
                    Looking for something not listed above? <strong>Contact us</strong> with your requirements, we can develop a <strong>custom plug-in or tool</strong> tailored to your specific
                    needs.
                </h2>
            </div>
        </div>
    </div>
</section>

{snippet contactForm}
    {include '../Components/contact-form-blue.latte', headline => 'false', description => 'false'}
{/snippet}



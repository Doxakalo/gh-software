            <div class="showMore overlay blue" style="background-image: url('{$basePath}/img/pages/qa/card_boxes/certification/certification.jpg')">
                <div class="rollover" style="background-image: url('{$basePath}/img/pages/qa/card_boxes/certification/certification_rollover.jpg')"></div>

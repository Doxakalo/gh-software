{import 'translate_'.$locale.'.latte'}
{block title}{_pages.qa.metadata.title}{/block}
{block description}{_pages.qa.metadata.description}{/block}

{block og}
    {ifset $appConfig["og"]}
        {capture $title}{_pages.qa.metadata.title}{/capture}
        {capture $description}{_generic.page-title.quality-assurance}{/capture}
        {capture $ogMediaHtml}
            <meta property='og:image' content='{$appConfig["url"]}/img/pages/qa/og_images/og_image_qa_1.jpg'>
            <meta property='og:image' content='{$appConfig["url"]}/img/pages/qa/og_images/og_image_qa_2.jpg'>
            <meta property='og:image' content='{$appConfig["url"]}/img/pages/qa/og_images/og_image_qa_3.jpg'>
            <meta property='og:image' content='{$appConfig["url"]}/img/pages/qa/og_images/og_image_qa_4.jpg'>
        {/capture}
        {include meta-og,
            type => $appConfig["og"]["type"],
            title => $title,
            description => $description,
            ogMediaHTML => $ogMediaHtml,
            siteName => $appConfig["og"]["site_name"]}
    {/ifset}
{/block}

{block content}
<section class="cover default extended">
    <div class="inner-background cover-parallax" style="background-image: url('{$basePath}/img/pages/qa/qa_header.jpg')"></div>
    <div class="container">
        <div class="row">
            <div class="gr-6 cover-parallax-inner">
                <div class="content">
                    <h1 class="page-title">
                        {_pages.qa.header-title}
                    </h1>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="info arrow">
    <div class="container">
        <div class="row row-align-center">
            <div class="item">
                <a n:href="Company:default#sw_testing">
                    <span class="counterHiddenElement">+</span><span class="number_counter" data-number-counter="true" data-number-counter-delay="300">10</span><span class="counterTempHiddenElement">+</span>
                    <p>{_pages.qa.counters.countries|noescape}</p>
                </a>
            </div>

            <div class="item">
                <a n:href="Company:default#sw_testing">
                    <span class="counterHiddenElement">+</span><span data-number-counter="true" data-number-counter-delay="600">15</span><span class="counterTempHiddenElement">+</span>
                    <p>{_pages.qa.counters.xp|noescape}</p>
                </a>
            </div>
            <div class="item">
                <a n:href="Company:default#sw_testing">
                    <span class="counterHiddenElement">+</span><span data-number-counter="true" data-number-counter-delay="900">25</span><span class="counterTempHiddenElement">+</span>
                    <p>{_pages.qa.counters.testers|noescape}</p>
                </a>
            </div>
            <div class="item">
                <a n:href="Company:default#sw_testing">
                    <span class="counterHiddenElement">+</span><span data-number-counter="true" data-number-counter-delay="1200" data-number-counter-tick="20">100</span><span class="counterTempHiddenElement">+</span>
                    <p>{_pages.qa.counters.projects|noescape}</p>
                </a>
            </div>
            <div class="item">
                <a n:href="Company:default#sw_testing">
                    <span class="counterHiddenElement">+</span><span data-number-counter="true" data-number-counter-delay="1500" data-number-counter-tick="3">500</span><span class="counterTempHiddenElement">+</span>
                    <p>{_pages.qa.counters.releases|noescape}</p>
                </a>
            </div>
        </div>
    </div>
</section>


{snippet contactForm}
    {include '../Components/contact-form-orange.latte', headline => 'false', description => 'false'}
{/snippet}

<section class="tile-panel arrow">
    <div class="row">

        <div class="tile gr-6 gr-12@mobile no-gutter padding-right padding-bottom" data-hightlight="true" data-hightlight-is-second="false"  data-highlight-full-width="false">
            <div class="showMore overlay blue" style="background-image: url('{$basePath}/img/pages/qa/card_boxes/teamwork/teamwork.jpg')">
                <div class="rollover" style="background-image: url('{$basePath}/img/pages/qa/card_boxes/teamwork/teamwork_rollover.jpg')"></div>
                <div class="content">
                    <div class="preview">{include teamwork_preview}</div>
                    <div class="detail">{include teamwork_details}</div>
                    <div class="read_more">{_pages.qa.card-boxes.button}</div>
                </div>
            </div>
        </div>
        <div class="tile gr-6 gr-12@mobile no-gutter padding-left padding-bottom" data-hightlight="true" data-hightlight-is-second="true"  data-highlight-full-width="false">
            <div class="showMore overlay blue" style="background-image: url('{$basePath}/img/pages/qa/card_boxes/professionality/professionality.jpg')">
        
                <div class="rollover" style="background-image: url('{$basePath}/img/pages/qa/card_boxes/professionality/professionality_rollover.jpg')"></div>
                <div class="content">
                    <div class="preview">{include professionality_preview}</div>
